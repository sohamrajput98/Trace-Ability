{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "TraceAbilityLogsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "TraceAbilityLogs",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "commit_id",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "commit_id",
            "KeyType": "HASH"
          }
        ]
      }
    }
  }
}